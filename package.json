  "description": "Sistema de escalas de limpeza e lavanderia da República Tabajara",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,ts,html --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,ts,html --fix",
